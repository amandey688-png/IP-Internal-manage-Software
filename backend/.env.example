# Supabase Configuration
# Copy this file to .env and fill in your values from Supabase Dashboard → Settings → API

# Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service Role Key (REQUIRED - has admin permissions)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anon Key (REQUIRED for login - use the JWT format eyJ... from anon public)
SUPABASE_ANON_KEY=your_anon_public_jwt_here

# Database URL (REQUIRED for automatic migrations)
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Use "Transaction" mode, replace [YOUR-PASSWORD] with your database password
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# JWT validation (replace YOUR_PROJECT_REF with your project ID from the URL)
JWT_AUDIENCE=authenticated
JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# Frontend URL - used for email confirmation redirect after user clicks link
# Local: http://localhost:3000  Production: https://ip-internal-manage-software.vercel.app
FRONTEND_URL=http://localhost:3000

# Public backend URL for email Approve/Reject links (fast HTML, no login). Must match uvicorn host/port.
# Local: http://127.0.0.1:8020   Production: https://your-api.onrender.com
PUBLIC_API_URL=http://127.0.0.1:8020

# CORS (required for production): comma-separated frontend origins
# Backend also reads CORS_ORIGIN, CORS_ORIGIN_1, CORS_ORIGIN_2, ... CORS_ORIGIN_10 (Render-style)
# industryprime.vercel.app is included in default production list
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://industryprime.vercel.app,https://ip-internal-manage-software.vercel.app

# ---------------------------------------------------------------------------
# Outgoing email (checklist / delegation reminders, etc.)
# send_email() order: SendGrid API → SMTP (see app/utils/email.py)
# ---------------------------------------------------------------------------

# Sender shown in emails (must match an address verified at your provider)
SMTP_FROM_EMAIL=noreply@your-verified-domain.com

# --- EMAIL PROVIDER (pick one) ---
#
# A) Postmark — SMTP, strong deliverability
#    Create a Server API token in Postmark and verify SMTP_FROM_EMAIL as a sender/signature.
#    Easiest setup:
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your_postmark_server_token
# SMTP_PASSWORD=your_postmark_server_token
# SMTP_FROM_EMAIL=noreply@your-verified-domain.com
#
#    Or use the app's Postmark aliases:
# POSTMARK_SERVER_TOKEN=your_postmark_server_token
# POSTMARK_FROM_EMAIL=noreply@your-verified-domain.com
#
# B) Brevo (ex-Sendinblue) — ~300 emails/day free, SMTP, good for India/global
#    Sign up: https://www.brevo.com → Settings → SMTP & API → generate SMTP key
#    Verify a sender email (or domain) under Senders & IP.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_brevo_login_email@example.com
# SMTP_PASSWORD=your_brevo_smtp_key
#
# C) SendGrid — ~100 emails/day free, HTTP API (works on Render without SMTP ports)
#    https://signup.sendgrid.com → API Keys → Create key → Sender Authentication
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=same-as-verified-sender@yourdomain.com
# SENDGRID_FROM_NAME=IP Internal Management
#
# D) Resend — generous free tier, SMTP: smtp.resend.com:587, user "resend", password=API key
#
# E) Gmail — free but low volume; Google Account → App passwords → SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=16_char_app_password

# Postmark SMTP (recommended) — Server API token as password; optional PM-T-outbound-* username
# POSTMARK_SMTP_HOST=smtp.postmarkapp.com
# POSTMARK_SMTP_PORT=587
# POSTMARK_SMTP_USERNAME=PM-T-outbound-...   # optional message stream
# POSTMARK_SMTP_TOKEN=your-server-api-token
# POSTMARK_FROM_EMAIL=verified@yourdomain.com
# POSTMARK_SERVER_TOKEN=   # alias for POSTMARK_SMTP_TOKEN (API or SMTP auth)

# Generic SMTP (local dev or any provider; on Render, try SMTP_PORT=2525 if 587 fails)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_PASS=   # alias for SMTP_PASSWORD
# SMTP_FROM_EMAIL=
# EMAIL_USE_SMTP=1   # force SMTP even if SENDGRID_API_KEY is set
# EMAIL_PROVIDER=postmark   # use Postmark when both Brevo SMTP_* and POSTMARK_* are in .env
# EMAIL_MODE=postmark       # postmark = send | log = dry-run (no SMTP)
# EMAIL_TEST_REDIRECT=you@example.com   # all outbound mail to one inbox (dev)
# FRONTEND_URL=https://your-app.vercel.app   # links in notification HTML

# (Optional) SendGrid — leave unset if using SMTP only
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=
# One-off SMTP test: POST /api/smtp/test with header X-SMTP-Test-Secret (must match) and optional JSON {"to":"..."}
# Or run:  cd backend && python scripts/test_smtp.py your@email.com
SMTP_TEST_SECRET=

# Secret for cron to call POST /checklist/send-daily-reminders (set X-Cron-Secret header)
CHECKLIST_CRON_SECRET=
# Optional: separate secret for delegation reminders. Falls back to CHECKLIST_CRON_SECRET if not set.
# DELEGATION_CRON_SECRET=

# Feature approval reminders: POST /api/feature-approval-reminders/run with X-Cron-Secret
# Falls back to NOTIFICATION_CRON_SECRET or CHECKLIST_CRON_SECRET if unset (see feature_approval_reminder_routes.py)
FEATURE_APPROVAL_CRON_SECRET=

# Pending escalation emails (cron-job.org / Render Cron / EasyCron):
# POST /api/escalation/send-pending-mails   — timeframe report (24–48 / 48–72 / 72hr+)
# POST /api/escalation/send-critical-mails  — critical 72hr+ only
# POST /api/escalation/send-stage-mails     — stage 2 / 3 / 4 pending (separate mail per enabled stage)
# Auth: Authorization: Bearer <secret>  OR  header X-Cron-Secret (same value)
ESCALATION_CRON_SECRET=
