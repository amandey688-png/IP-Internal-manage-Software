# Local: MUST be the same host:port as uvicorn. Vite proxies /api/* here. After changing uvicorn --port, change this and restart npm run dev.
VITE_API_BASE_URL=http://127.0.0.1:8020
# Optional: set to 0 only if you want the browser to call VITE_API_BASE_URL directly (no /api proxy).
# VITE_DEV_SAME_ORIGIN_PROXY=0

# Production: see committed .env.production (used by vite build on Vercel).
# Override in Vercel → Environment Variables if your API URL differs.
# VITE_API_BASE_URL=https://ip-internal-manage-software.onrender.com
